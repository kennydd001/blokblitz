{
  "name": "blokblitz-dino-redders",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local-first educational action game where number structures control gameplay.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build",
    "qa:viewport": "node scripts/viewport-qa.mjs",
    "qa:mobile-touch": "node scripts/mobile-touch-qa.mjs",
    "deploy:sprintsite": "npm run build && npx --yes wrangler@latest deploy",
    "deploy:sprintsite:dry-run": "npm run build && npx --yes wrangler@latest deploy --dry-run",
    "voice:hestia": "node scripts/generate-hestia-voice-pack.mjs",
    "voice:elevenlabs": "node scripts/generate-elevenlabs-voice-pack.mjs && node scripts/generate-elevenlabs-reading-phoneme-pack.mjs",
    "voice:elevenlabs-reading": "node scripts/generate-elevenlabs-reading-phoneme-pack.mjs",
    "voice:elevenlabs-reading-shootout": "node scripts/elevenlabs-reading-shootout.mjs",
    "voice:elevenlabs-audit": "node scripts/audit-elevenlabs-audio.mjs",
    "voice:ratings-server": "node scripts/tts-rating-server.mjs",
    "voice:record-reading": "node scripts/reading-recording-studio.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/three": "^0.184.1",
    "esbuild": "^0.27.7",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
